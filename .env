# ── Entorno (local / production) ──
APP_ENV=production

# ── URL pública del proyecto ──
# Ej: https://tudominio.com/facturacionfeja
APP_URL=https://tudominio.com/facturacionfeja

# ── Base de datos MySQL ──
DB_HOST=localhost
DB_PORT=3306
DB_NAME=facturacionfeja
DB_USER=tu_usuario
DB_PASS=tu_contraseña

# ── API SUNAT (valores por defecto para nuevos usuarios) ──
# Se sobreescribe desde la interfaz de Configuración
#API_DEFAULT_BASE_URL=https://apiprueba.moabcode.com/api/v1
#API_DEFAULT_KEY=
#API_DEFAULT_SECRET=
